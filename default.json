{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "schedule": [
    "before 9am on sunday"
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "matchCurrentVersion": "!/^0/",
      "automerge": true
    },
    {
      "groupName": "github workflows",
      "matchManagers": [
        "github-actions"
      ],
      "matchFileNames": [
        ".github/workflows/**"
      ]
    }    
  ]  
}
